{
  "scripts": {
    "clean": "rimraf bin cache dist obj output temp wwwroot",
    "build": "webpack --config webpack.prod.ts",
    "serve": "webpack serve --config webpack.dev.ts",
    "format:check": "prettier --check $npm_package_config_prettierglob_1 --check $npm_package_config_prettierglob_2",
    "format:fix": "prettier --write $npm_package_config_prettierglob_1 --write $npm_package_config_prettierglob_2",
    "lint": "eslint ."
  },
  "config": {
    "prettierglob_1": "./*.{js,json,ts}",
    "prettierglob_2": "./content/**/*.{css,js,jsx,json,md,scss,ts,tsx}"
  },
  "devDependencies": {
    "clean-webpack-plugin": "^4.0.0",
    "eslint": "^8.57.0",
    "html-bundler-webpack-plugin": "^3.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "sass": "^1.72.0",
    "sass-loader": "^14.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "webpack": "^5.91.0",
    "webpack-clean-plugin": "^0.2.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-merge": "^5.10.0"
  }
}
